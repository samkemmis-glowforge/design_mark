# Copy to .env (gitignored) or export before running. Different jobs need different keys.

# --- Asset indexer (npm run index:drive) ---
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json
DRIVE_FOLDER_ID=1QBmbHWpsQKTmfEihdrv4atc-G2DDFyDV
GEMINI_API_KEY=your-gemini-key

# --- Slack bot (npm run slack) — in production these live in Secret Manager, see slack/DEPLOY.md ---
SLACK_BOT_TOKEN=xoxb-...        # Bot User OAuth token (Slack app → OAuth & Permissions)
SLACK_APP_TOKEN=xapp-...        # App-Level token w/ connections:write (Socket Mode)
ANTHROPIC_API_KEY=sk-ant-...    # the agent's brain
# GEMINI_API_KEY also used by the bot for image generation (see above)

# --- MCP server (npm run mcp), optional ---
# DESIGN_MCP_TOKEN=...           # bearer token consumers must send
# IMAGE_PROVIDER=gemini
